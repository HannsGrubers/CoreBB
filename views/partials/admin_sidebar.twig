<aside class="corebb-admin-sidebar" aria-label="Admin tools">
    {% for group in layout.nav.groups|default([]) %}
        <section class="corebb-admin-nav-group">
            <h2>{{ group.label }}</h2>
            <div class="corebb-admin-nav-links">
                {% for item in group.items %}
                    <a class="corebb-admin-nav-link{% if item.active %} is-active{% endif %}{% if item.special %} is-special{% endif %}" href="{{ item.url }}">
                        <span>{{ item.label }}</span>
                        {% if item.badge|default(0) > 0 %}
                            <strong>{{ item.badge }}</strong>
                        {% endif %}
                    </a>
                {% endfor %}
            </div>
        </section>
    {% endfor %}
</aside>
