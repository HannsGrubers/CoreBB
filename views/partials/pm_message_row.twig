{% set pmId = message.id|default(0) %}
{% set method = message.method|default('unread') %}
<tr>
    <td class="PrivMsgListRowA">
        &nbsp;&nbsp;<img src="{{ asset('images/x.gif') }}" width="18" height="18" alt="" class="wb-img-middle">
        <a href="/private-messages/message/{{ pmId }}/{{ method }}/" class="PrivMsgViewLink">{{ message.title|default('') }}</a>
        <a class="PrivMsgViewText">{{ message.direction|default('from') }}</a>
        <a class="PrivMsgUsername">{% include 'partials/user_name.twig' with {user: user_name_model(message.other_user_id|default(0), message.other_user_name|default('Unknown'), false)} only %}</a>
    </td>
    <td colspan="2" class="PrivMsgListRowA"><div class="PrivMsgViewText wb-text-center">{{ message.date_sent_display|default('') }}</div></td>
</tr>
