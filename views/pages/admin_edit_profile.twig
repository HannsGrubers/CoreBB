{% include 'partials/admin_messages.twig' with {messages: model.messages|default([]), errors: model.errors|default([])} only %}
{% set mode = model.mode|default('search') %}
{% set user = model.user|default(null) %}
{% set profile = model.profile|default({}) %}
{% set fields = model.fields|default([]) %}

<div class="corebb-admin-modern-page">
    {% if model.message|default('') != '' %}
        <div class="corebb-admin-modern-note">{{ model.message|replace({'+': ' '}) }}</div>
    {% endif %}

    <div class="corebb-admin-modern-header">
        <div>
            <div class="corebb-admin-modern-eyebrow">People</div>
            <h2>{{ mode == 'edit' and user ? 'Edit User Profile' : 'Find User Profile' }}</h2>
            <div class="corebb-admin-modern-meta">
                {% if user %}
                    <span>{{ user.username|default('') }}</span>
                    <span>#{{ user.id|default(0) }}</span>
                    <span>{{ user.accesslevel|default(0) }} - {{ user.level_name|default('') }}</span>
                {% else %}
                    <span>Search by username or user ID.</span>
                {% endif %}
            </div>
        </div>
        <div class="corebb-admin-modern-actions">
            {% if user %}
                <a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Public Profile</a>
                <a class="corebb-board-action-link" href="/admin/?act=edit_profile">Find Another User</a>
            {% endif %}
            <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
        </div>
    </div>

    {% if mode == 'edit' and user %}
        <table class="corebb-admin-modern-table corebb-admin-profile-summary-table wb-table">
            <tbody>
                <tr>
                    <th>User Name</th>
                    <td>{{ user.username|default('') }}</td>
                </tr>
                <tr>
                    <th>Public Profile</th>
                    <td><a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Open Profile</a></td>
                </tr>
                <tr>
                    <th>UID</th>
                    <td>{{ user.id|default(0) }}</td>
                </tr>
                <tr>
                    <th>User Level</th>
                    <td>{{ user.accesslevel|default(0) }} <span class="corebb-admin-modern-help">{{ user.level_name|default('') }}</span></td>
                </tr>
            </tbody>
        </table>

        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=edit_profile&amp;method=save">
                {% include 'partials/csrf_field.twig' %}
                <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                <input type="hidden" name="admin_edit_profile_token" value="{{ model.token|default('') }}">

                <div class="corebb-admin-section-title">Profile Fields</div>
                <div class="corebb-admin-modern-grid">
                    {% for field in fields %}
                        <label for="corebbProfile{{ field.key|default(loop.index) }}">{{ field.label|default('') }}</label>
                        <input id="corebbProfile{{ field.key|default(loop.index) }}" name="{{ field.key|default('') }}" type="text" size="50" maxlength="{{ field.maxlength|default(255) }}" value="{{ profile[field.key]|default('') }}">
                    {% endfor %}

                    <div class="corebb-admin-section-title corebb-admin-modern-full">Picture</div>
                    <label for="corebbProfilePicture">Picture URL</label>
                    <input id="corebbProfilePicture" name="profpic" type="text" size="50" maxlength="255" value="{{ profile.profpic|default('') }}">

                    <div class="corebb-admin-section-title corebb-admin-modern-full">Bio</div>
                    <label for="corebbProfileBio">Bio</label>
                    <span>
                        <textarea id="corebbProfileBio" name="bio" cols="65" rows="7">{{ profile.bio|default('') }}</textarea>
                        <span class="corebb-admin-modern-help">Board markup is allowed. HTML is stripped.</span>
                    </span>

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <button class="corebb-board-action-link" type="submit">Apply Changes</button>
                        <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/?act=edit_profile';">Find Another User</button>
                        <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/';">Admin Home</button>
                    </div>
                </div>
            </form>
        </div>
    {% else %}
        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=edit_profile&amp;method=view">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label for="corebbEditProfileUser">User</label>
                    <span>
                        <input id="corebbEditProfileUser" type="text" name="user" value="{{ model.search_value|default('') }}">
                        <button class="corebb-board-action-link" type="submit">Submit</button>
                        <span class="corebb-admin-modern-help">Username or user ID.</span>
                    </span>
                </div>
            </form>
        </div>
    {% endif %}
</div>
