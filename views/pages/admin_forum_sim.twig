{% include 'partials/admin_messages.twig' with {messages: model.messages|default([]), errors: model.errors|default([])} only %}
{% set settings = model.settings|default({}) %}
{% set boards = model.eligible_boards|default([]) %}
{% set selectedBoard = settings.target_board|default(0) %}

<div class="corebb-admin-modern-page">
    <div class="corebb-admin-modern-header">
        <div>
            <div class="corebb-admin-modern-eyebrow">System</div>
            <h2>Forum Sim-Test</h2>
            <div class="corebb-admin-modern-meta">
                <span>{{ boards|length|number_format }} eligible boards</span>
                <span>{{ model.planned_posts|default(0)|number_format }} planned posts/replies</span>
                <span>{{ model.planned_polls|default(0)|number_format }} polls</span>
            </div>
        </div>
        <div class="corebb-admin-modern-actions">
            <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
        </div>
    </div>

    <div class="corebb-admin-modern-split">
        <div class="corebb-admin-modern-choice">
            <h3>Archive Safety</h3>
            <p>This tool only selects public, non-archive boards as targets. It creates new generated users, new generated topics, and replies only inside generated topics from the same run. Existing archive users, archive boards, archive topics, and archive posts are not used.</p>
        </div>
        <div class="corebb-admin-modern-choice">
            <h3>Eligible Boards</h3>
            <p>{{ boards|length|number_format }} public non-archive board{{ boards|length == 1 ? '' : 's' }} available.</p>
            {% if boards %}
                <span class="corebb-admin-modern-help">
                    Examples:
                    {% for board in boards|slice(0, 5) %}
                        {% if not loop.first %}, {% endif %}{{ board.category_name|default('') }} / {{ board.name|default('') }}
                    {% endfor %}
                </span>
            {% endif %}
        </div>
    </div>

    <div class="corebb-admin-modern-note is-muted">
        Maximum posts/replies: {{ model.planned_posts|default(0)|number_format }}. Maximum per run: {{ model.max_posts|default(0)|number_format }}. Maximum polls/votes: {{ model.planned_polls|default(0)|number_format }} / {{ model.planned_votes|default(0)|number_format }}. Vote maximum per run: {{ model.max_votes|default(0)|number_format }}.
    </div>

    <div class="corebb-admin-modern-panel">
        <div class="corebb-admin-section-title">Simulation Size</div>
        <form class="corebb-admin-modern-form" method="post" action="/admin/?act=forum_sim">
            {% include 'partials/csrf_field.twig' %}
            <input type="hidden" name="action" value="run_forum_sim">
            <div class="corebb-admin-modern-grid">
                <label for="corebbSimUsers">Regular Users</label>
                <span>
                    <input id="corebbSimUsers" type="text" name="users" size="6" value="{{ settings.users|default(25) }}">
                    <span class="corebb-admin-modern-help">1-250.</span>
                </span>

                <label for="corebbSimTargetBoard">Target Board</label>
                <span>
                    <select id="corebbSimTargetBoard" name="target_board">
                        <option value="0">All eligible boards</option>
                        {% for board in boards %}
                            {% set boardId = board.id|default(0) %}
                            <option value="{{ boardId }}"{% if boardId == selectedBoard %} selected{% endif %}>{{ board.category_name|default('')|trim }} / {{ board.name|default('')|trim }}</option>
                        {% endfor %}
                    </select>
                    <span class="corebb-admin-modern-help">Choose one board, or leave as all eligible boards.</span>
                </span>

                <label for="corebbSimMods">Moderator Users</label>
                <span>
                    <select id="corebbSimMods" name="mods">
                        <option value="1"{% if settings.mods|default(2) == 1 %} selected{% endif %}>1</option>
                        <option value="2"{% if settings.mods|default(2) == 2 %} selected{% endif %}>2</option>
                    </select>
                    <span class="corebb-admin-modern-help">Generated users with Moderator rank for simulated mod actions.</span>
                </span>

                <label for="corebbSimTopics">New Threads</label>
                <span><input id="corebbSimTopics" type="text" name="topics" size="6" value="{{ settings.topics|default(40) }}"> <span class="corebb-admin-modern-help">1-500.</span></span>

                <label for="corebbSimReplies">Replies Per Thread</label>
                <span><input id="corebbSimReplies" type="text" name="replies" size="6" value="{{ settings.replies|default(5) }}"> <span class="corebb-admin-modern-help">0-25 maximum. Actual replies per generated thread are randomized.</span></span>

                <label for="corebbSimPollTopics">Poll Threads</label>
                <span><input id="corebbSimPollTopics" type="text" name="poll_topics" size="6" value="{{ settings.poll_topics|default(8) }}"> <span class="corebb-admin-modern-help">0-250 generated threads receive polls.</span></span>

                <label for="corebbSimPollVotes">Votes Per Poll</label>
                <span><input id="corebbSimPollVotes" type="text" name="poll_votes" size="6" value="{{ settings.poll_votes|default(10) }}"> <span class="corebb-admin-modern-help">0-100 maximum. Generated users vote with uneven frequency.</span></span>

                <label for="corebbSimRegistrationSpan">Registration Span</label>
                <span><input id="corebbSimRegistrationSpan" type="text" name="registration_span_days" size="6" value="{{ settings.registration_span_days|default(365) }}"> <span class="corebb-admin-modern-help">1-5000 days for generated account registration dates.</span></span>

                <label for="corebbSimPostSpan">Post Activity Span</label>
                <span><input id="corebbSimPostSpan" type="text" name="span_days" size="6" value="{{ settings.span_days|default(14) }}"> <span class="corebb-admin-modern-help">1-90 days for generated post dates.</span></span>

                <label for="corebbSimEdits">Moderator Edits</label>
                <span><input id="corebbSimEdits" type="text" name="edits" size="6" value="{{ settings.edits|default(25) }}"> <span class="corebb-admin-modern-help">0-500.</span></span>

                <label for="corebbSimTopicActions">Lock/Sticky Actions</label>
                <span><input id="corebbSimTopicActions" type="text" name="topic_actions" size="6" value="{{ settings.topic_actions|default(10) }}"> <span class="corebb-admin-modern-help">0-250.</span></span>

                <label for="corebbSimConfirm">Confirm</label>
                <span>
                    <input id="corebbSimConfirm" type="text" name="confirm" size="12" value="">
                    <span class="corebb-admin-modern-help">Type <strong>SIMULATE</strong>. This writes real database rows.</span>
                </span>

                <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                    <button class="corebb-board-action-link" type="submit"{% if boards is empty %} disabled{% endif %}>Run Forum Sim-Test</button>
                </div>
            </div>
        </form>
    </div>

    <div class="corebb-admin-modern-panel">
        <div class="corebb-admin-section-title">Remove Generated Simulation Data</div>
        <form class="corebb-admin-modern-form" method="post" action="/admin/?act=forum_sim">
            {% include 'partials/csrf_field.twig' %}
            <input type="hidden" name="action" value="wipe_forum_sim">
            <div class="corebb-admin-modern-grid">
                <label for="corebbSimWipeConfirm">Confirm Wipe</label>
                <span>
                    <input id="corebbSimWipeConfirm" type="text" name="wipe_confirm" size="12" value="">
                    <span class="corebb-admin-modern-help">Type <strong>WIPE SIM</strong>. This removes generated sim users, topics, posts, polls, and votes.</span>
                </span>

                <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                    <button class="corebb-board-action-link is-danger" type="submit">Wipe Sim Data</button>
                </div>
            </div>
        </form>
    </div>
</div>
