{% include 'partials/admin_messages.twig' with {messages: model.messages|default([]), errors: model.errors|default([])} only %}
{% set mode = model.mode|default('search') %}

<div class="corebb-admin-modern-page">
    {% if model.message|default('') != '' %}
        <div class="corebb-admin-modern-note">{{ model.message|replace({'+': ' '}) }}</div>
    {% endif %}

    {% if mode == 'edit' %}
        {% set user = model.user|default({}) %}
        <div class="corebb-admin-modern-header">
            <div>
                <div class="corebb-admin-modern-eyebrow">People</div>
                <h2>Change User Password</h2>
                <div class="corebb-admin-modern-meta">
                    <span>{{ user.username|default('Unknown User') }}</span>
                    <span>#{{ user.id|default(0) }}</span>
                    <span>{{ user.accesslevel|default(0) }} - {{ user.level_name|default('') }}</span>
                </div>
            </div>
            <div class="corebb-admin-modern-actions">
                <a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Public Profile</a>
                <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
            </div>
        </div>

        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=change_user_password&amp;method=save" autocomplete="off">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <span class="corebb-admin-modern-label">User Name</span>
                    <span>{{ user.username|default('') }}</span>

                    <span class="corebb-admin-modern-label">UID</span>
                    <span>{{ user.id|default(0) }}</span>

                    <label for="corebbUserPassword">Set User's Password To</label>
                    <input id="corebbUserPassword" name="password1" type="password">

                    <label for="corebbUserPasswordConfirm">Confirm Password Change</label>
                    <input id="corebbUserPasswordConfirm" name="password2" type="password">

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <button class="corebb-board-action-link" type="submit">Apply Changes</button>
                        <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
                        <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                    </div>
                </div>
            </form>
        </div>
    {% else %}
        <div class="corebb-admin-modern-header">
            <div>
                <div class="corebb-admin-modern-eyebrow">People</div>
                <h2>Change User Password</h2>
                <div class="corebb-admin-modern-meta">
                    <span>Find a user by username or ID.</span>
                </div>
            </div>
            <div class="corebb-admin-modern-actions">
                <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
            </div>
        </div>

        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=change_user_password&amp;method=view">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label for="corebbPasswordUserSearch">Username or User ID</label>
                    <input id="corebbPasswordUserSearch" name="user" type="text">

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <button class="corebb-board-action-link" type="submit">Submit</button>
                    </div>
                </div>
            </form>
        </div>
    {% endif %}
</div>
