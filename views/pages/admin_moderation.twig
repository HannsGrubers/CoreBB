{% include 'partials/admin_messages.twig' with {messages: model.messages|default([]), errors: model.errors|default([])} only %}
{% set mode = model.mode|default('ban') %}
{% set token = model.token|default('') %}
{% set confirmUser = model.confirm_user|default(null) %}
{% set tabs = [
    {key: 'ban', label: 'Ban User'},
    {key: 'unban', label: 'Unban User'},
    {key: 'requests', label: 'Unban Requests'}
] %}

<div class="corebb-admin-modern-page">
    <div class="corebb-admin-modern-header">
        <div>
            <div class="corebb-admin-modern-eyebrow">Moderation</div>
            <h2>Moderation Tools</h2>
            <div class="corebb-admin-modern-meta">
                <span>{{ mode == 'ban' ? 'Ban active users' : (mode == 'unban' ? 'Review banned users' : 'Handle unban requests') }}</span>
            </div>
        </div>
        <div class="corebb-admin-modern-actions">
            {% for tab in tabs %}
                {% if mode == tab.key %}
                    <span class="corebb-board-action-disabled">{{ tab.label }}</span>
                {% else %}
                    <a class="corebb-board-action-link" href="/admin/?act=moderation&amp;mode={{ tab.key }}">{{ tab.label }}</a>
                {% endif %}
            {% endfor %}
            <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
        </div>
    </div>

    {% if confirmUser and model.confirm_action|default('') == 'ban' %}
        <div class="corebb-admin-modern-panel">
            <div class="corebb-admin-section-title">Confirm Ban</div>
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=moderation&amp;mode=ban">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label>User</label>
                    <span><a class="corebb-admin-text-link" href="{{ confirmUser.profile_url }}">{{ confirmUser.username }}</a> <span class="corebb-admin-modern-help">#{{ confirmUser.id|default(0) }}</span></span>

                    <label>Level</label>
                    <span>{{ confirmUser.accesslevel|default(0) }} - {{ confirmUser.level_name|default('') }}</span>

                    <label for="corebbBanReason">Reason</label>
                    <span>
                        <textarea id="corebbBanReason" name="reason" cols="60" rows="5"></textarea>
                        <span class="corebb-admin-modern-help">Optional, but recommended. This is visible to moderators/admins.</span>
                    </span>

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <input type="hidden" name="action" value="ban_save">
                        <input type="hidden" name="userid" value="{{ confirmUser.id|default(0) }}">
                        <input type="hidden" name="admin_moderation_token" value="{{ token }}">
                        <button class="corebb-board-action-link is-danger" type="submit">Ban User</button>
                        <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/?act=moderation&amp;mode=ban';">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    {% elseif confirmUser and model.confirm_action|default('') == 'unban' %}
        <div class="corebb-admin-modern-panel">
            <div class="corebb-admin-section-title">Confirm Unban</div>
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=moderation&amp;mode=unban">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label>User</label>
                    <span><a class="corebb-admin-text-link" href="{{ confirmUser.profile_url }}">{{ confirmUser.username }}</a> <span class="corebb-admin-modern-help">#{{ confirmUser.id|default(0) }}</span></span>

                    <label>Banned</label>
                    <span>{{ confirmUser.banned_at|default('Unknown') != '' ? confirmUser.banned_at : 'Unknown' }}</span>

                    {% if confirmUser.ban_reason|default('') != '' %}
                        <label>Ban Reason</label>
                        <span class="corebb-admin-prewrap">{{ confirmUser.ban_reason }}</span>
                    {% endif %}

                    <label for="corebbUnbanNote">Admin Note</label>
                    <span>
                        <textarea id="corebbUnbanNote" name="note" cols="60" rows="5"></textarea>
                        <span class="corebb-admin-modern-help">Optional note for the admin log.</span>
                    </span>

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <input type="hidden" name="action" value="unban_save">
                        <input type="hidden" name="userid" value="{{ confirmUser.id|default(0) }}">
                        <input type="hidden" name="admin_moderation_token" value="{{ token }}">
                        <button class="corebb-board-action-link" type="submit">Unban User</button>
                        <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/?act=moderation&amp;mode=unban';">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    {% endif %}

    {% if mode == 'ban' and not confirmUser %}
        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="get" action="/admin/">
                <input type="hidden" name="act" value="moderation">
                <input type="hidden" name="mode" value="ban">
                <div class="corebb-admin-modern-grid">
                    <label for="corebbBanSearch">Find User</label>
                    <span>
                        <input id="corebbBanSearch" type="text" name="q" value="{{ model.query|default('') }}" size="35">
                        <button class="corebb-board-action-link" type="submit">Search</button>
                        <span class="corebb-admin-modern-help">Username, user ID, email, or IP for an active user.</span>
                    </span>
                </div>
            </form>
        </div>

        {% if model.results|default([]) %}
            <table class="corebb-admin-modern-table wb-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Level</th>
                        <th>Posts</th>
                        <th>Last IP</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in model.results %}
                        <tr>
                            <td><a class="corebb-admin-text-link" href="{{ user.profile_url }}">{{ user.username }}</a> <span class="corebb-admin-modern-help">#{{ user.id|default(0) }}</span></td>
                            <td>{{ user.accesslevel|default(0) }} - {{ user.level_name|default('') }}</td>
                            <td>{{ user.posts|default(0)|number_format }}</td>
                            <td>{{ user.last_ip|default('') }}</td>
                            <td>
                                <form class="corebb-admin-modern-form" method="post" action="/admin/?act=moderation&amp;mode=ban">
                                    {% include 'partials/csrf_field.twig' %}
                                    <input type="hidden" name="action" value="ban_confirm">
                                    <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                                    <input type="hidden" name="admin_moderation_token" value="{{ token }}">
                                    <button class="corebb-board-action-link is-danger" type="submit">Ban</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    {% elseif mode == 'unban' and not confirmUser %}
        {% set unbanSearch = model.unban_search|default({username: '', ip_address: '', host_address: ''}) %}
        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="get" action="/admin/">
                <input type="hidden" name="act" value="moderation">
                <input type="hidden" name="mode" value="unban">
                <div class="corebb-admin-modern-grid">
                    <label for="corebbUnbanUsername">User Name</label>
                    <input id="corebbUnbanUsername" type="text" name="username" value="{{ unbanSearch.username|default('') }}">

                    <label for="corebbUnbanIp">IP Address</label>
                    <input id="corebbUnbanIp" type="text" name="ip_address" value="{{ unbanSearch.ip_address|default('') }}">

                    <label for="corebbUnbanHost">Host Address</label>
                    <input id="corebbUnbanHost" type="text" name="host_address" value="{{ unbanSearch.host_address|default('') }}">

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <button class="corebb-board-action-link" type="submit">Search</button>
                    </div>
                </div>
            </form>
        </div>

        <table class="corebb-admin-modern-table wb-table">
            <thead>
                <tr>
                    <th>Moderator</th>
                    <th>User</th>
                    <th>IP Address</th>
                    <th>Date Banned</th>
                    <th>Reason</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if model.results|default([]) is empty %}
                    <tr>
                        <td colspan="6" class="corebb-admin-modern-empty">No banned users found.</td>
                    </tr>
                {% else %}
                    {% for user in model.results %}
                        <tr>
                            <td>
                                {% if user.banned_by_username|default('') != '' and user.banned_by_profile_url|default('') != '' %}
                                    <a class="corebb-admin-text-link" target="_top" href="{{ user.banned_by_profile_url }}">{{ user.banned_by_username }}</a>
                                {% elseif user.banned_by|default(0) > 0 %}
                                    #{{ user.banned_by }}
                                {% endif %}
                            </td>
                            <td><a class="corebb-admin-text-link" target="_top" href="{{ user.profile_url }}">{{ user.username }}</a></td>
                            <td>
                                {% if user.last_ip|default('') != '' %}
                                    <a class="corebb-admin-text-link" href="/admin/?act=moderation&amp;mode=unban&amp;ip_address={{ user.last_ip|url_encode }}">{{ user.last_ip }}</a>
                                {% endif %}
                            </td>
                            <td>{{ user.banned_at_vn|default('') != '' ? user.banned_at_vn : '' }}</td>
                            <td><span class="corebb-admin-prewrap">{{ user.ban_reason|default('') }}</span></td>
                            <td>
                                <form class="corebb-admin-modern-form" method="post" action="/admin/?act=moderation&amp;mode=unban" onsubmit="return confirm('Are you sure you want to unban this user?');">
                                    {% include 'partials/csrf_field.twig' %}
                                    <input type="hidden" name="action" value="unban_save">
                                    <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                                    <input type="hidden" name="admin_moderation_token" value="{{ token }}">
                                    <input type="hidden" name="username" value="{{ unbanSearch.username|default('') }}">
                                    <input type="hidden" name="ip_address" value="{{ unbanSearch.ip_address|default('') }}">
                                    <input type="hidden" name="host_address" value="{{ unbanSearch.host_address|default('') }}">
                                    <button class="corebb-board-action-link" type="submit">Unban</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    {% elseif mode == 'requests' %}
        {% set counts = model.request_counts|default({}) %}
        {% set requests = model.requests|default({items: [], total: 0, page: 1, total_pages: 1}) %}
        {% set requestsView = model.requests_view|default({is_old: false, title: 'New Unban Requests', toggle_href: '/admin/?act=moderation&mode=requests&responded=True', toggle_text: 'Click here for Old Unban Requests'}) %}
        {% set respondRequest = model.respond_request|default(null) %}

        <div class="corebb-admin-modern-note is-muted">
            Pending: {{ counts.pending|default(0)|number_format }}. Resolved: {{ counts.resolved|default(0)|number_format }}. Total: {{ counts.all|default(0)|number_format }}.
        </div>

        {% if respondRequest %}
            <div class="corebb-admin-modern-panel">
                <div class="corebb-admin-section-title">Respond To Unban Request</div>
                <form class="corebb-admin-modern-form" method="post" action="/admin/?act=moderation&amp;mode=requests{% if requestsView.is_old|default(false) %}&amp;responded=True{% endif %}">
                    {% include 'partials/csrf_field.twig' %}
                    <div class="corebb-admin-modern-grid">
                        <label>User</label>
                        <span><a class="corebb-admin-text-link" target="_top" href="{{ respondRequest.profile_url|default('#') }}">{{ respondRequest.username|default('#' ~ respondRequest.userid|default(0)) }}</a> <span class="corebb-admin-modern-help">#{{ respondRequest.userid|default(0) }}</span></span>

                        <label>Reason</label>
                        <span class="corebb-admin-prewrap">{{ respondRequest.request_text|default('') }}</span>

                        <label for="corebbUnbanRequestNote">Moderator Response</label>
                        <textarea id="corebbUnbanRequestNote" name="admin_note" cols="70" rows="5"></textarea>

                        <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                            <input type="hidden" name="request_id" value="{{ respondRequest.id|default(0) }}">
                            <input type="hidden" name="admin_moderation_token" value="{{ token }}">
                            <button class="corebb-board-action-link" type="submit" name="action" value="request_approve" onclick="return confirm('Are you sure you want to approve this unban request?');">Approve + Unban</button>
                            <button class="corebb-board-action-link is-danger" type="submit" name="action" value="request_deny" onclick="return confirm('Are you sure you want to deny this unban request?');">Deny Request</button>
                            <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/?act=moderation&amp;mode=requests{% if requestsView.is_old|default(false) %}&amp;responded=True{% endif %}';">Cancel</button>
                        </div>
                    </div>
                </form>
            </div>
        {% endif %}

        <div class="corebb-admin-modern-panel">
            <div class="corebb-admin-modern-header">
                <div>
                    <div class="corebb-admin-modern-eyebrow">Unban Requests</div>
                    <h2>{{ requestsView.title|default('New Unban Requests') }}</h2>
                    <div class="corebb-admin-modern-meta">
                        <span>{{ requests.total|default(0)|number_format }} total</span>
                        <span>Page {{ requests.page|default(1)|number_format }} of {{ requests.total_pages|default(1)|number_format }}</span>
                    </div>
                </div>
                <div class="corebb-admin-modern-actions">
                    <a class="corebb-board-action-link" href="{{ requestsView.toggle_href|default('/admin/?act=moderation&mode=requests&responded=True') }}">{{ requestsView.toggle_text|default('Old Unban Requests') }}</a>
                </div>
            </div>

            <table class="corebb-admin-modern-table corebb-admin-unban-requests-table wb-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Banned By</th>
                        <th>IP / Host</th>
                        <th>Date Added</th>
                        <th>Verified</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if requests.items|default([]) is empty %}
                        <tr>
                            <td colspan="6" class="corebb-admin-modern-empty">No unban requests found.</td>
                        </tr>
                    {% else %}
                        {% for req in requests.items %}
                            <tr>
                                <td><a class="corebb-admin-text-link" target="_top" href="{{ req.profile_url|default('#') }}">{{ req.username|default('#' ~ req.userid|default(0)) }}</a></td>
                                <td>
                                    {% if req.banned_by_username|default('') != '' %}
                                        <a class="corebb-admin-text-link" target="_top" href="{{ req.banned_by_url|default('#') }}">{{ req.banned_by_username }}</a>
                                    {% elseif req.banned_by|default(0) > 0 %}
                                        #{{ req.banned_by }}
                                    {% else %}
                                        Unknown
                                    {% endif %}
                                </td>
                                <td class="corebb-admin-unban-host-cell">
                                    <a class="corebb-admin-text-link corebb-admin-unban-host-link" href="{{ req.host_lookup_url|default('#') }}">{{ req.ip_address|default('') }}<br>{{ req.host_address|default('') }}</a>
                                </td>
                                <td>{{ req.created_at_vn|default('') != '' ? req.created_at_vn : req.created_at|default('') }}</td>
                                <td>{{ req.verified|default('False') }}</td>
                                <td>
                                    <div class="corebb-admin-modern-submit">
                                        <a class="corebb-board-action-link" href="{{ req.notes_url|default('#') }}">Admin Notes</a>
                                        {% if req.status|default('pending') == 'pending' %}
                                            <form class="corebb-admin-modern-form" method="get" action="/admin/">
                                                <input type="hidden" name="act" value="moderation">
                                                <input type="hidden" name="mode" value="requests">
                                                <input type="hidden" name="respond" value="{{ req.id|default(0) }}">
                                                <button class="corebb-board-action-link" type="submit">Respond</button>
                                            </form>
                                        {% else %}
                                            <span class="corebb-admin-modern-help">Responded</span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6">
                                    <strong>Reason:</strong> <span class="corebb-admin-prewrap">{{ req.request_text|default('') }}</span>
                                    {% if req.status|default('pending') != 'pending' %}
                                        <br><strong>Moderator Response:</strong> <span class="corebb-admin-prewrap">{{ req.admin_note|default('') }}</span>
                                        {% if req.resolved_at_vn|default('') != '' %}<br><span class="corebb-admin-modern-help">Resolved: {{ req.resolved_at_vn }}</span>{% endif %}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>

            {% if requests.pagination.visible|default(false) %}
                <div class="corebb-admin-modern-panel wb-text-center">{% include 'partials/board_pagination.twig' with {pagination: requests.pagination} only %}</div>
            {% endif %}
        </div>
    {% endif %}
</div>
