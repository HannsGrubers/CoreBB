{% include 'partials/pm_menu.twig' %}

<div class="wb-pm-page">
<table class="wb-cellspace-1 wb-cellpad-0 wb-table" style="width: 100%;"><tr><td>
    {% include 'partials/pm_folder_counts.twig' with {counts: model.counts|default({}), active: model.folder|default('unread')} only %}

    <form class="wb-pm-form" name="form1" method="post" action="" style="margin:0; padding:0;">
        {% include 'partials/csrf_field.twig' %}
        <table class="wb-pm-section-table wb-cellspace-1 wb-cellpad-0 wb-table" style="width: 100%;">
            <tr>
                <td colspan="2" class="BoardColumn" style="width: 90%;">&nbsp;&nbsp;<img src="{{ asset('images/folder-open.gif') }}" width="18" height="18" alt="" class="wb-img-middle">&nbsp;{{ model.title|default('Private Messages') }}</td>
                <td class="BoardColumn" style="width: 10%;"><div class="wb-text-center">Date Sent</div></td>
            </tr>
            {% if model.messages|default([]) is empty %}
                <tr><td colspan="3" class="PrivMsgListRowA">&nbsp;&nbsp;<a class="SmallText">This folder is currently empty.</a></td></tr>
            {% else %}
                {% for message in model.messages|default([]) %}
                    {% include 'partials/pm_message_row.twig' with {message: message} only %}
                {% endfor %}
            {% endif %}
        </table>
    </form>
</td></tr></table>
</div>
