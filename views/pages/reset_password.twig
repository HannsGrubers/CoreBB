<table class="wb-cellspace-1 wb-cellpad-0 wb-table" style="width: 100%;">
    <tr>
        <td class="BoardColumn"><b>Reset Password</b></td>
    </tr>
    <tr class="BoardRowB">
        <td style="padding: 10px;">
            <p>{{ model.message|default('') }}</p>

            {% if model.done|default(false) %}
                <p><a class="BoardRowBLink" href="{{ url('auth.php?action=login') }}">Continue to Login</a></p>
            {% elseif model.valid|default(false) %}
                {% if model.username|default('') != '' %}
                    <p><b>Account:</b> {{ model.username }}</p>
                {% endif %}
                <form method="post" action="{{ url('auth.php?action=reset') }}">
                    {% include 'partials/csrf_field.twig' %}
                    <input type="hidden" name="token" value="{{ model.token|default('') }}">
                    <span class="InputSection">New Password:</span><br>
                    <input type="password" name="pass1" size="25" maxlength="72" autocomplete="new-password"><br>
                    <span class="InputSection">Confirm Password:</span><br>
                    <input type="password" name="pass2" size="25" maxlength="72" autocomplete="new-password"><br><br>
                    <input type="submit" value=" Reset Password ">
                </form>
            {% else %}
                <p><a class="BoardRowBLink" href="{{ url('auth.php?action=recover') }}">Request a New Recovery Link</a></p>
            {% endif %}
        </td>
    </tr>
</table>
