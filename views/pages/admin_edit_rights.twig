{% macro tool_groups(toolGroups, interactive) %}
    <div class="corebb-admin-action-stack">
        {% for group, tools in toolGroups %}
            <div>
                <div class="corebb-admin-modern-label">{{ group }} Tools</div>
                <div class="corebb-admin-tool-options">
                    {% for tool in tools %}
                        {% set key = tool.key|default('') %}
                        {% set selected = tool.selected|default(false) %}
                        {% set inherited = tool.inherited|default(false) %}
                        <label class="corebb-admin-tool-option">
                            <input type="checkbox" name="admin_tools[]" value="{{ key }}"{% if selected or inherited %} checked{% endif %}{% if not interactive or inherited %} disabled{% endif %}>
                            <span>{{ tool.label|default(key) }}{% if inherited %} <span class="corebb-admin-modern-help">(rank)</span>{% endif %}</span>
                        </label>
                        {% if not interactive and selected and not inherited %}
                            <input type="hidden" name="admin_tools[]" value="{{ key }}">
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endmacro %}

{% import _self as rights %}
{% include 'partials/admin_messages.twig' with {messages: model.messages|default([]), errors: model.errors|default([])} only %}
{% set mode = model.mode|default('search') %}
{% set levels = model.levels|default({}) %}
{% set toolGroups = model.tool_groups|default({}) %}
{% set canManageToolGrants = model.can_manage_tool_grants|default(false) %}

<div class="corebb-admin-modern-page">
    {% if model.message|default('') != '' %}
        <div class="corebb-admin-modern-note">{{ model.message|replace({'+': ' '}) }}</div>
    {% endif %}

    {% set user = model.user|default(null) %}
    <div class="corebb-admin-modern-header">
        <div>
            <div class="corebb-admin-modern-eyebrow">People</div>
            <h2>{{ mode == 'confirm' ? 'Confirm User Rights' : (mode == 'view' ? 'Edit User Rights' : 'Find User Rights') }}</h2>
            <div class="corebb-admin-modern-meta">
                {% if user %}
                    <span>{{ user.username|default('') }}</span>
                    <span>#{{ user.id|default(0) }}</span>
                    <span>{{ user.accesslevel|default(0) }} - {{ user.level_name|default('') }}</span>
                {% else %}
                    <span>Search by username or user ID.</span>
                {% endif %}
            </div>
        </div>
        <div class="corebb-admin-modern-actions">
            {% if user %}
                <a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Public Profile</a>
            {% endif %}
            <a class="corebb-board-action-link" href="/admin/">Admin Home</a>
        </div>
    </div>

    {% if mode == 'confirm' %}
        {% set user = model.user|default({}) %}
        <table class="corebb-admin-modern-table corebb-admin-profile-summary-table wb-table">
            <tbody>
                <tr><th>User Name</th><td>{{ user.username|default('') }}</td></tr>
                <tr><th>Public Profile</th><td><a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Open Profile</a></td></tr>
                <tr><th>UID</th><td>{{ user.id|default(0) }}</td></tr>
                <tr><th>Current Level</th><td>{{ user.accesslevel|default(0) }} <span class="corebb-admin-modern-help">{{ user.level_name|default('') }}</span></td></tr>
                <tr><th>New Level</th><td>{{ model.new_level|default(0) }} <span class="corebb-admin-modern-help">{{ model.new_level_name|default('') }}</span></td></tr>
            </tbody>
        </table>

        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=edit_rights&amp;method=save">
                {% include 'partials/csrf_field.twig' %}
                {% if canManageToolGrants and toolGroups %}
                    <div class="corebb-admin-section-title">Additional Tool Access</div>
                    {{ rights.tool_groups(toolGroups, false) }}
                {% endif %}
                <div class="corebb-admin-modern-submit">
                    <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                    <input type="hidden" name="userslevel" value="{{ model.new_level|default(0) }}">
                    <button class="corebb-board-action-link" type="submit">Confirm Changes</button>
                    <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/';">Admin Home</button>
                </div>
            </form>
        </div>
    {% elseif mode == 'view' %}
        {% set user = model.user|default({}) %}
        <table class="corebb-admin-modern-table corebb-admin-profile-summary-table wb-table">
            <tbody>
                <tr><th>User Name</th><td>{{ user.username|default('') }}</td></tr>
                <tr><th>Public Profile</th><td><a class="corebb-board-action-link" href="{{ user.profile_url|default('#') }}">Open Profile</a></td></tr>
                <tr><th>UID</th><td>{{ user.id|default(0) }}</td></tr>
                <tr><th>User Level</th><td>{{ user.accesslevel|default(0) }} <span class="corebb-admin-modern-help">{{ user.level_name|default('') }}</span></td></tr>
            </tbody>
        </table>

        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=edit_rights&amp;method=confirm">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label for="corebbUserLevel">Set User's Level To</label>
                    <select id="corebbUserLevel" name="userlevel">
                        {% for value, label in levels %}<option value="{{ value }}"{% if value == user.accesslevel|default(0) %} selected{% endif %}>{{ label }}</option>{% endfor %}
                    </select>

                    {% if canManageToolGrants and toolGroups %}
                        <div class="corebb-admin-modern-full">
                            <div class="corebb-admin-section-title">Additional Tool Access</div>
                            <div class="corebb-admin-modern-note is-muted">Checked tools grant access beyond the user's normal rank. Tools marked (rank) are already included by their selected level.</div>
                            {{ rights.tool_groups(toolGroups, true) }}
                        </div>
                    {% endif %}

                    <div class="corebb-admin-modern-submit corebb-admin-modern-full">
                        <input type="hidden" name="userid" value="{{ user.id|default(0) }}">
                        <button class="corebb-board-action-link" type="submit">Apply Changes</button>
                        <button class="corebb-board-action-link" type="button" onclick="window.location.href='/admin/';">Admin Home</button>
                    </div>
                </div>
            </form>
        </div>
    {% else %}
        <div class="corebb-admin-modern-panel">
            <form class="corebb-admin-modern-form" method="post" action="/admin/?act=edit_rights&amp;method=view">
                {% include 'partials/csrf_field.twig' %}
                <div class="corebb-admin-modern-grid">
                    <label for="corebbEditRightsUser">User</label>
                    <span>
                        <input id="corebbEditRightsUser" type="text" name="username">
                        <button class="corebb-board-action-link" type="submit">Submit</button>
                        <span class="corebb-admin-modern-help">Username or user ID.</span>
                    </span>
                </div>
            </form>
        </div>
    {% endif %}
</div>
