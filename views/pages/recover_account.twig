<table class="wb-cellspace-1 wb-cellpad-0 wb-table" style="width: 100%;">
    <tr>
        <td class="BoardColumn"><b>Account Recovery</b></td>
    </tr>
    <tr class="BoardRowB">
        <td style="padding: 10px;">
            {% if model.submitted|default(false) %}
                <p>{{ model.message|default('') }}</p>
                {% if model.mail_error|default('') != '' %}
                    <p class="ErrorFont">{{ model.mail_error }}</p>
                {% endif %}

                {% if model.debug_status|default([]) is not empty %}
                    <br>
                    <table class="wb-cellspace-1 wb-cellpad-4 wb-table" style="width: 100%;">
                        <tr>
                            <td colspan="3" class="BoardColumn"><b>Password Recovery Mail Debug</b></td>
                        </tr>
                        <tr class="BoardRowA">
                            <td class="InputSection" style="width: 24%;"><b>Step</b></td>
                            <td class="InputSection" style="width: 18%;"><b>Status</b></td>
                            <td class="InputSection"><b>Details</b></td>
                        </tr>
                        {% for row in model.debug_status %}
                            <tr class="BoardRowB">
                                <td>{{ row.step|default('') }}</td>
                                <td>{{ row.status|default('') }}</td>
                                <td>{{ row.detail|default('') }}</td>
                            </tr>
                        {% endfor %}
                    </table>
                    <p class="SmallText">This debug block is intended for staging diagnostics. It does not display SMTP passwords or email body contents.</p>
                {% endif %}

                <p><a class="BoardRowBLink" href="{{ url('auth.php?action=login') }}">Return to Login</a></p>
            {% else %}
                <p>Enter the email address on your account. If it matches an account, a password reset link will be emailed to you.</p>
                <form method="post" action="{{ url('auth.php?action=recover') }}">
                    {% include 'partials/csrf_field.twig' %}
                    <span class="InputSection">Email Address:</span><br>
                    <input type="email" name="email" size="35" maxlength="255" autocomplete="email"><br><br>
                    <input type="submit" value=" Send Recovery Email ">
                </form>
                <p><a class="BoardRowBLink" href="{{ url('auth.php?action=login') }}">Return to Login</a></p>
            {% endif %}
        </td>
    </tr>
</table>
