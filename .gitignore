# ------------------------------------------------------------
# CoreBB local/private secrets and generated runtime artifacts
# ------------------------------------------------------------
/config.local.php
/.env
/corebb_private/
/composer.phar

/error_log
/invalidaccess.txt
/logs/*.log
/logs/*.txt
/cache/*
/tmp/*
/temp/*
/sessions/*

# Keep protection/placeholders if present.
!/cache/.htaccess
!/cache/.keep

# ------------------------------------------------------------
# User-generated uploads: keep folder protection, not live content
# ------------------------------------------------------------
/images/post_uploads/*
!/images/post_uploads/.htaccess
!/images/post_uploads/.keep
!/images/post_uploads/index.html

/images/user_avatars/*
!/images/user_avatars/.htaccess
!/images/user_avatars/.keep
!/images/user_avatars/index.html

# ------------------------------------------------------------
# Database dumps, backup archives, patch packages
# ------------------------------------------------------------
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz
*.7z
*.rar
*.bak
*.backup
*.old
*.orig

# Required by the fresh-install web installer.
!/lib/install_schema.sql

# ------------------------------------------------------------
# OS/editor/hosting noise
# ------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
.cpanel-datastore/
.buildpath
.project
/.settings
